# ── Azure OpenAI (get from Azure Portal > Keys & Endpoint)
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── Azure AI Search (get from Azure Portal > Search resource)
AZURE_SEARCH_ENDPOINT=https://YOUR-SEARCH-NAME.search.windows.net
AZURE_SEARCH_API_KEY=your-search-key-here
AZURE_SEARCH_INDEX_NAME=riskwise-index

# ── Azure SQL (optional for now)
AZURE_SQL_CONNECTION_STRING=your-connection-string-here

# ── App Settings
APP_NAME=RiskWise 2.0
DEBUG=True
